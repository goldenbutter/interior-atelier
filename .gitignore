# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local-only screenshots, mcp scratch, and AI-generated assets that shouldn't ship in git
/.playwright-mcp/
/_local/
/public/generated/
*.jpeg

# allow tracked imagery under public/assets/img to remain
!public/assets/img/*.jpeg

# Claude Code per-developer settings
.claude/settings.local.json
