# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any depth — applies to root + each prototype)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local-only screenshots, mcp scratch, AI-generated assets — gitignored anywhere in the tree
.playwright-mcp/
_local/
public/generated/
*.jpeg

# Whisk scratch folder — kept locally for re-rolls, never committed
prototypes/whisk-image/

# allow tracked imagery under any public/assets/img to remain
!**/public/assets/img/*.jpeg

# Claude Code working notes, agent instructions, settings — never committed
.claude/
CLAUDE.md
AGENTS.md
**/CLAUDE.md
**/AGENTS.md

# Per-prototype Nano Banana staging
_public/

# Agent-internal artifacts (build log, asset-gen pipeline, lead research, prospect lists, search prompts, decisions)
# Whole tree hidden from GitHub — for me + Claude agent only
_docs/

# IDE / editor settings
.vscode/
